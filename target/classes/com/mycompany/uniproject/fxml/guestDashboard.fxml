<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="600" prefWidth="800" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.uniproject.controllers.GuestDashboardController">
    <top>
        <HBox alignment="CENTER" style="-fx-padding: 15; -fx-background-color: #1a3a5c;">
            <Label style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: white;" text="Ain Shams Grand Hotel" />
        </HBox>
    </top>
    <left>
        <VBox spacing="10" style="-fx-padding: 20; -fx-background-color: #1a3a5c;">
            <Button fx:id="browseRoomsButton" maxWidth="Infinity" onAction="#handleBrowseRooms" text="Browse Rooms" />
            <Button fx:id="myReservationsButton" maxWidth="Infinity" onAction="#handleMyReservations" text="My Reservations" />
            <Button fx:id="checkoutButton" maxWidth="Infinity" onAction="#handleCheckout" text="Checkout" />
            <Button fx:id="chatButton" maxWidth="Infinity" onAction="#handleChat" text="Chat" />
            <Button fx:id="logoutButton" maxWidth="Infinity" onAction="#handleLogout" text="Logout" />
         <Button fx:id="hotelServicesButton" mnemonicParsing="false" onAction="#handleHotelServices" text="Hotel Services" />
        </VBox>
    </left>
    <center>
        <VBox alignment="CENTER" spacing="15" style="-fx-padding: 20;">
            <Label fx:id="welcomeLabel" style="-fx-font-size: 18; -fx-font-weight: bold;" text="Welcome, Guest" />
            <Label fx:id="balanceLabel" style="-fx-font-size: 14;" text="Balance: $0.0" />
            <Label fx:id="reservationsLabel" style="-fx-font-size: 14;" text="Active Reservations:" />
         <ListView fx:id="activeReservationsListView" prefHeight="150.0" prefWidth="150.0" />
        </VBox>
    </center>
</BorderPane>
